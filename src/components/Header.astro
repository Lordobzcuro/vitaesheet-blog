---
import { SITE_TITLE, APP_URL, LP_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href={LP_URL} class="logo-link" target="_blank" title="VitaeSheet — Fichas Digitais para RPG Vampiro">
			<img src="/logo.svg" alt="VitaeSheet" class="logo-icon" width="28" height="28" />
			<span class="logo-text">VitaeSheet</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Início</HeaderLink>
			<HeaderLink href="/blog">Artigos</HeaderLink>
			<HeaderLink href="/about">Sobre</HeaderLink>
		</div>
		<div class="cta-nav">
			<a href={APP_URL} target="_blank" class="nav-cta">Criar Ficha Grátis</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1.5em;
		background: rgba(10, 10, 10, 0.92);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-width-wide);
		margin: 0 auto;
		height: 56px;
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		color: var(--blood-glow);
		font-family: 'Cinzel', serif;
		font-size: 1.05em;
		font-weight: 700;
		border-bottom: none !important;
	}
	.logo-link:hover {
		color: var(--blood-light);
		text-decoration: none;
	}
	.logo-icon {
		flex-shrink: 0;
		border-radius: 4px;
	}
	.logo-text {
		white-space: nowrap;
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
	}
	nav a {
		padding: 0.5em 0.75em;
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.9em;
		font-weight: 500;
		border-radius: var(--radius-sm);
		transition: color 0.2s ease, background 0.2s ease;
	}
	nav a:hover {
		color: var(--text-primary);
		background: rgba(255, 255, 255, 0.04);
		text-decoration: none;
	}
	nav a.active {
		color: var(--text-primary);
		background: rgba(139, 0, 0, 0.12);
	}
	.nav-cta {
		padding: 0.45em 1.1em !important;
		background: var(--blood);
		color: #fff !important;
		border-radius: var(--radius-sm);
		font-size: 0.85em;
		font-weight: 600;
	}
	.nav-cta:hover {
		background: var(--blood-light);
		color: #fff !important;
		box-shadow: 0 0 12px rgba(139, 0, 0, 0.3);
	}
	@media (max-width: 720px) {
		header { padding: 0 1em; }
		.cta-nav { display: none; }
		.internal-links { gap: 0; }
		nav a { padding: 0.5em; font-size: 0.85em; }
		.logo-text { display: none; }
	}
</style>
