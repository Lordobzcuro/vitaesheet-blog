---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { APP_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-width: var(--max-width);
				margin: 0 auto var(--spacing-xl);
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: var(--radius-lg);
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: var(--max-width);
				max-width: calc(100% - 2em);
				margin: auto;
				padding: var(--spacing-md);
				color: var(--text-primary);
			}
			.article-header {
				margin-bottom: var(--spacing-2xl);
				padding-bottom: var(--spacing-xl);
				border-bottom: 1px solid var(--border);
			}
			.article-header h1 {
				margin: 0 0 var(--spacing-md) 0;
				line-height: 1.2;
			}
			.meta {
				display: flex;
				align-items: center;
				gap: var(--spacing-md);
				color: var(--text-muted);
				font-size: 0.88em;
				font-weight: 500;
			}
			.last-updated-on {
				font-style: italic;
			}
			.post-cta {
				text-align: center;
				margin: var(--spacing-2xl) 0 var(--spacing-md);
				padding: var(--spacing-xl);
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: var(--radius-lg);
			}
			.post-cta p {
				color: var(--text-secondary);
				margin-bottom: var(--spacing-md);
				font-size: 1.05em;
				line-height: 1.6;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="article-header">
						<h1>{title}</h1>
						<div class="meta">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="last-updated-on">
										· Atualizado em <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</div>
					</div>
					{heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)}
					<slot />
					<div class="post-cta">
						<p>Chega de fichas perdidas, anotações bagunçadas e XP calculado na mão. O VitaeSheet organiza tudo pra você — de graça.</p>
						<a href={APP_URL} class="cta-button" target="_blank">Criar Minha Ficha</a>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
