---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, APP_URL } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 6);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: var(--spacing-3xl) var(--spacing-md) var(--spacing-2xl);
				max-width: 640px;
				margin: 0 auto;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.4em;
				background: linear-gradient(135deg, var(--text-primary) 0%, var(--blood-glow) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero .subtitle {
				color: var(--text-secondary);
				font-size: 1.1em;
				line-height: 1.7;
				margin-bottom: var(--spacing-xl);
			}
			.section-title {
				text-align: center;
				font-size: 1.3em;
				color: var(--text-secondary);
				margin-bottom: var(--spacing-lg);
				font-weight: 400;
			}
			.posts-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: var(--spacing-lg);
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.posts-grid li:first-child {
				grid-column: 1 / -1;
			}
			.posts-grid a {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				padding: var(--spacing-lg) var(--spacing-xl);
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: var(--radius-lg);
				transition: all 0.25s ease;
				height: 100%;
			}
			.posts-grid a:hover {
				border-color: var(--blood);
				background: var(--bg-card-hover);
				box-shadow: 0 4px 24px rgba(139, 0, 0, 0.1);
				transform: translateY(-2px);
				text-decoration: none;
			}
			.posts-grid .title {
				font-family: 'Cinzel', serif;
				color: var(--text-primary);
				margin: 0 0 var(--spacing-sm);
				font-size: 1.1em;
				line-height: 1.35;
			}
			.posts-grid li:first-child .title {
				font-size: 1.45em;
			}
			.posts-grid .date {
				color: var(--text-muted);
				font-size: 0.82em;
				margin: 0 0 var(--spacing-xs);
				font-weight: 500;
			}
			.posts-grid .desc {
				color: var(--text-secondary);
				font-size: 0.9em;
				margin: var(--spacing-sm) 0 0;
				line-height: 1.6;
			}
			@media (max-width: 720px) {
				.posts-grid { grid-template-columns: 1fr; gap: var(--spacing-md); }
				.hero h1 { font-size: 1.8em; }
				.hero { padding: var(--spacing-xl) var(--spacing-md); }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Crônicas das Trevas</h1>
				<p class="subtitle">
					Sua mesa de RPG Vampiro merece mais do que fichas perdidas e anotações bagunçadas. Guias, dicas e tudo que um mestre precisa.
				</p>
				<a href={APP_URL} class="cta-button" target="_blank">Crie Sua Ficha Grátis</a>
			</section>

			<h2 class="section-title">Últimos Artigos</h2>

			<ul class="posts-grid">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h4 class="title">{post.data.title}</h4>
							<p class="desc">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
