---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, APP_URL } from '../consts';

const now = new Date();
const posts = (await getCollection('blog'))
	.filter((post) => post.data.pubDate.valueOf() <= now.valueOf())
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);

const tagColorMap: Record<string, string> = {
	'Guia': 'tag-guia',
	'Clãs': 'tag-clas',
	'Narração': 'tag-narracao',
};
function getTagClass(tag: string) {
	return tagColorMap[tag] || 'tag-default';
}
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero */
			.hero {
				text-align: center;
				padding: var(--spacing-3xl) var(--spacing-md) var(--spacing-2xl);
				max-width: 640px;
				margin: 0 auto;
				position: relative;
			}
			.hero-eyebrow {
				font-family: 'Cinzel', serif;
				font-size: 0.65em;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: var(--blood);
				margin-bottom: var(--spacing-md);
			}
			.hero h1 {
				font-family: 'Cinzel Decorative', 'Cinzel', serif;
				font-size: 2.5em;
				font-weight: 700;
				margin-bottom: 0.4em;
				color: var(--text-primary);
				line-height: 1.2;
			}
			.hero h1 em {
				font-style: normal;
				color: var(--gold);
			}
			.hero .subtitle {
				color: var(--text-secondary);
				font-size: 1.1em;
				line-height: 1.7;
				margin-bottom: var(--spacing-xl);
				font-style: italic;
			}
			.hero-divider {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1rem;
				margin-top: var(--spacing-xl);
			}
			.hero-divider-line {
				flex: 1;
				max-width: 120px;
				height: 1px;
				background: linear-gradient(to right, transparent, var(--border-light));
			}
			.hero-divider-line.rev {
				background: linear-gradient(to left, transparent, var(--border-light));
			}
			.hero-divider .sym {
				color: var(--blood);
				font-size: 1.1em;
				line-height: 1;
			}

			/* Section label */
			.section-label {
				font-family: 'Cinzel', serif;
				font-size: 0.65em;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: var(--blood);
				margin-bottom: var(--spacing-lg);
				display: flex;
				align-items: center;
				gap: 0.8rem;
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: var(--border);
			}

			/* Posts grid */
			.posts-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: var(--spacing-lg);
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.posts-grid li:first-child {
				grid-column: 1 / -1;
			}
			.posts-grid a {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				padding: var(--spacing-lg) var(--spacing-xl);
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 2px;
				transition: all 0.25s ease;
				height: 100%;
				position: relative;
			}
			/* Blood left border */
			.posts-grid a::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				width: 2px;
				background: var(--blood);
				border-radius: 2px 0 0 2px;
				opacity: 0.6;
				transition: opacity 0.25s ease;
			}
			.posts-grid a:hover::before {
				opacity: 1;
			}
			.posts-grid a:hover {
				border-color: rgba(139, 0, 0, 0.3);
				background: var(--bg-card-hover);
				box-shadow: 0 4px 24px rgba(139, 0, 0, 0.08);
				transform: translateY(-2px);
				text-decoration: none;
			}

			/* Featured card */
			.posts-grid li:first-child a {
				background: rgba(19, 11, 16, 0.8);
				border-color: rgba(90, 37, 64, 0.4);
				border-top: 2px solid var(--blood);
			}
			.featured-badge {
				font-family: 'Cinzel', serif;
				font-size: 0.6em;
				letter-spacing: 2px;
				text-transform: uppercase;
				color: var(--gold);
				background: rgba(30, 16, 16, 0.8);
				border: 1px solid rgba(90, 32, 32, 0.5);
				padding: 2px 10px;
				display: inline-block;
				margin-bottom: var(--spacing-sm);
				width: fit-content;
			}

			/* Post meta */
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				margin-bottom: var(--spacing-sm);
				flex-wrap: wrap;
			}
			.posts-grid .title {
				font-family: 'Cinzel', serif;
				color: var(--text-primary);
				margin: 0 0 var(--spacing-sm);
				font-size: 1.1em;
				line-height: 1.35;
			}
			.posts-grid li:first-child .title {
				font-size: 1.45em;
			}
			.posts-grid .date {
				color: var(--text-muted);
				font-size: 0.75em;
				font-family: 'Cinzel', serif;
				letter-spacing: 1px;
			}
			.posts-grid .desc {
				color: var(--text-secondary);
				font-size: 0.9em;
				margin: var(--spacing-sm) 0 0;
				line-height: 1.6;
				font-style: italic;
			}

			/* Card footer */
			.card-footer {
				display: flex;
				align-items: center;
				justify-content: flex-end;
				margin-top: auto;
				padding-top: var(--spacing-md);
			}
			.read-more {
				font-family: 'Cinzel', serif;
				font-size: 0.65em;
				letter-spacing: 2px;
				text-transform: uppercase;
				color: var(--gold);
				transition: color 0.2s;
			}
			.read-more:hover {
				color: var(--gold-dim);
			}

			@media (max-width: 720px) {
				.posts-grid { grid-template-columns: 1fr; gap: var(--spacing-md); }
				.posts-grid a { padding: var(--spacing-md); }
				.posts-grid li:first-child .title { font-size: 1.2em; }
				.hero h1 { font-size: 1.8em; }
				.hero { padding: var(--spacing-xl) var(--spacing-md); }
			}
			@media (max-width: 480px) {
				.hero h1 { font-size: 1.5em; }
				.hero .subtitle { font-size: 0.95em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="hero-eyebrow">&#10013; Cr&ocirc;nicas das Trevas &#10013;</p>
				<h1>Bem-vindo &agrave;s<br/><em>Noites Imortais</em></h1>
				<p class="subtitle">
					Guias, dicas e tudo que um mestre de RPG Vampiro precisa. Sua mesa merece mais do que fichas perdidas e anota&ccedil;&otilde;es bagun&ccedil;adas.
				</p>
		<div class="hero-divider">
					<div class="hero-divider-line"></div>
					<span class="sym">&#10013;</span>
					<div class="hero-divider-line rev"></div>
				</div>
			</section>

			<p class="section-label">&Uacute;ltimos artigos</p>

			<ul class="posts-grid">
				{posts.map((post, i) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							{i === 0 && <span class="featured-badge">&#10022; Em destaque</span>}
							<div class="post-meta">
								{post.data.tags && (post.data.tags as string[]).map((tag: string) => (
									<span class={`tag ${getTagClass(tag)}`}>{tag}</span>
								))}
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</div>
							<h4 class="title">{post.data.title}</h4>
							<p class="desc">{post.data.description}</p>
							<div class="card-footer">
								<span class="read-more">Ler artigo &rarr;</span>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
