---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, APP_URL } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 6);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3em 1em 2em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.3em;
			}
			.hero .subtitle {
				color: var(--text-secondary);
				font-size: 1.1em;
				margin-bottom: 2em;
				max-width: 600px;
				margin-left: auto;
				margin-right: auto;
			}
			.posts-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2em;
				list-style: none;
				padding: 0;
				margin: 2em 0;
			}
			.posts-grid li:first-child {
				grid-column: 1 / -1;
			}
			.posts-grid a {
				display: block;
				text-decoration: none;
				padding: 1.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 12px;
				transition: all 0.3s ease;
			}
			.posts-grid a:hover {
				border-color: var(--blood);
				background: var(--bg-card-hover);
				box-shadow: 0 0 30px rgba(139, 0, 0, 0.1);
			}
			.posts-grid .title {
				font-family: 'Cinzel', serif;
				color: var(--text-primary);
				margin: 0 0 0.3em;
				font-size: 1.2em;
				line-height: 1.3;
			}
			.posts-grid li:first-child .title {
				font-size: 1.6em;
			}
			.posts-grid .date {
				color: var(--text-muted);
				font-size: 0.85em;
				margin: 0;
			}
			.posts-grid .desc {
				color: var(--text-secondary);
				font-size: 0.9em;
				margin: 0.5em 0 0;
				line-height: 1.5;
			}
			@media (max-width: 720px) {
				.posts-grid {
					grid-template-columns: 1fr;
				}
				.hero h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Crônicas das Trevas</h1>
				<p class="subtitle">
					Sua mesa de RPG Vampiro merece mais do que fichas perdidas e anotações bagunçadas. Guias, dicas e tudo que um mestre precisa.
				</p>
				<a href={APP_URL} class="cta-button" target="_blank">Crie Sua Ficha Grátis</a>
			</section>

			<h2 style="text-align: center; margin-top: 2em;">Últimos Artigos</h2>

			<ul class="posts-grid">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<h4 class="title">{post.data.title}</h4>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="desc">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
